{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "198aa0a6-d2ed-4f35-b41b-b6f6778a30d6",
  "developer": {
    "name": "Synozur",
    "websiteUrl": "https://www.synozur.com",
    "privacyUrl": "https://www.synozur.com/privacy",
    "termsOfUseUrl": "https://www.synozur.com/terms"
  },
  "name": {
    "short": "Constellation",
    "full": "Constellation - Synozur Consulting Delivery Platform"
  },
  "description": {
    "short": "View project dashboards and status reports from Constellation.",
    "full": "Constellation is the Synozur Consulting Delivery Platform (SCDP). This tab lets you view project dashboards, status reports, RAIDD logs, financial metrics, and team performance data directly inside Microsoft Teams."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#1E3A5F",
  "configurableTabs": [
    {
      "configurationUrl": "https://constellation.synozur.com/embed/configure",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupChat"]
    }
  ],
  "staticTabs": [
    {
      "entityId": "constellation-dashboard",
      "name": "My Projects",
      "contentUrl": "https://constellation.synozur.com/embed/dashboard",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [
    "constellation.synozur.com",
    "*.synozur.com"
  ],
  "webApplicationInfo": {
    "id": "198aa0a6-d2ed-4f35-b41b-b6f6778a30d6",
    "resource": "api://constellation.synozur.com/198aa0a6-d2ed-4f35-b41b-b6f6778a30d6"
  }
}
